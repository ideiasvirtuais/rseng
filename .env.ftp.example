# Credenciais para `bun run deploy:ftp`
# Copie este arquivo para `.env.ftp` e preencha com seus dados reais.
# `.env.ftp` está no .gitignore — nunca comite senhas.
#
# Como usar:
#   set -a && source .env.ftp && set +a
#   bun run deploy:ftp                     # envia dist/client/ para o FTP
#   bun run deploy:ftp -- --dry-run        # só lista o que seria enviado
#   bun run deploy:ftp -- --dry-run --delete   # inclui obsoletos a remover
#   bun run deploy:ftp -- --delete         # envia e remove obsoletos

# --- Obrigatórios ---
FTP_HOST=ftp.rsengenharia.eng.br
FTP_USER=seu_usuario
FTP_PASSWORD=sua_senha_aqui

# --- Opcionais (valores mostrados são os defaults) ---
# FTP_PORT=21
# FTP_SECURE=false            # "true" (FTPS explícito), "implicit" (FTPS implícito), "false"
# FTP_REMOTE_DIR=/www         # raiz web na KingHost/Napoleon: /www ou /public_html
# FTP_LOCAL_DIR=dist/client
# FTP_LOG_FILE=dist/deploy-ftp.log

# --- Modo simulação / limpeza (também podem vir por flag na CLI) ---
# FTP_DRY_RUN=true
# FTP_DELETE_OBSOLETE=true
# FTP_FORCE=true              # ignora manifesto de checksum e reenvia tudo
# FTP_MANIFEST_NAME=.deploy-manifest.json  # nome do manifesto SHA-256 remoto

# --- Paralelismo e retentativas ---
# FTP_CONCURRENCY=3           # nº de conexões FTP simultâneas
# FTP_MAX_RETRIES=3           # tentativas por arquivo antes de falhar
# FTP_RETRY_DELAY_MS=1000     # backoff exponencial base (1s, 2s, 4s, …)
